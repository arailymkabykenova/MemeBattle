# =============================================================================
# MEME CARD GAME - BACKEND ENVIRONMENT VARIABLES
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL="postgresql+asyncpg://username:password@localhost/meme_card_game"

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
# Path to Firebase Admin SDK JSON file
FIREBASE_CREDENTIALS_PATH="./firebase-admin-sdk.json"
# Or use GOOGLE_APPLICATION_CREDENTIALS environment variable
# GOOGLE_APPLICATION_CREDENTIALS="./firebase-admin-sdk.json"

# Firebase Project ID
FIREBASE_PROJECT_ID="your-firebase-project-id"

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET_KEY="your-super-secret-jwt-key-minimum-32-characters-long-CHANGE-IN-PRODUCTION"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_HOURS=168  # 7 days

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL="redis://localhost:6379/0"
REDIS_PASSWORD=""

# =============================================================================
# AZURE BLOB STORAGE CONFIGURATION
# =============================================================================
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net"
AZURE_CONTAINER_NAME="meme-cards"


# =============================================================================
AZURE_OPENAI_ENDPOINT
AZURE_OPENAI_KEY
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-35-turbo
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_TITLE="Meme Card Game API"
API_VERSION="1.0.0"
API_DESCRIPTION="Backend API for iOS Meme Card Game"

# =============================================================================
# CELERY CONFIGURATION (for background tasks)
# =============================================================================
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL="INFO"
LOG_FILE_PATH="./logs/app.log"

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEBUG=True
TESTING=False
ENVIRONMENT="development"
